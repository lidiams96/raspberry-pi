# Copia este archivo a .env y rellena los valores:  cp env.example .env

# Contrasena del panel web de Pi-hole
WEBPASSWORD=cambia_esto

# (Opcional) Auth key de Tailscale para autenticar sin interaccion.
# Generala en https://login.tailscale.com/admin/settings/keys
# Si lo dejas vacio, autentica a mano:  docker exec tailscale tailscale up
TS_AUTHKEY=

# Host(s):puerto desde los que abres Homepage (separados por comas).
# Es una lista de nombres permitidos en la URL (protección anti DNS-rebinding),
# NO un control de qué dispositivos pueden conectarse.
#   - raspberrypi.local:3000               -> en la LAN (dispositivos que resuelven .local)
#   - <IP-LAN>:3000                         -> en la LAN, por IP (p. ej. Android)
#   - raspberrypi:3000                      -> por VPN Tailscale (nombre corto MagicDNS)
#   - raspberrypi.<tu-tailnet>.ts.net:3000  -> por VPN Tailscale (nombre completo MagicDNS)
HOMEPAGE_ALLOWED_HOSTS=raspberrypi.local:3000,192.168.1.146:3000,raspberrypi:3000,raspberrypi.<tu-tailnet>.ts.net:3000

# Clave de API de Pi-hole para el widget del dashboard.
# Pi-hole admin -> Settings -> API -> "App password" (o tu contraseña de admin).
PIHOLE_API_KEY=
